{
    "name": "core-fe",
    "version": "1.43.2",
    "main": "lib/index.js",
    "module": "lib/index.js",
    "types": "lib/index.d.ts",
    "license": "MIT",
    "files": [
        "lib",
        "src"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/neowu/core-fe-project.git"
    },
    "scripts": {
        "lint": "eslint --no-warn-ignored \"./{src,test}/**\"",
        "format": "prettier --write \"{src,test,config}/**/*.{js,jsx,ts,tsx,mts,mjs,json}\"",
        "format-check": "prettier --check \"{src,test,config}/**/*.{js,jsx,ts,tsx,mts,mjs,json}\"",
        "test": "vitest run --config ./config/vitest.config.ts",
        "build": "pnpm format-check && pnpm lint && pnpm test && pnpm build:fast",
        "build:fast": "rm -rf ./lib && tsc --composite false",
        "prepublishOnly": "pnpm build:fast"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "14.6.1",
        "@types/node": "25.6.0",
        "eslint": "10.2.1",
        "globals": "17.5.0",
        "prettier": "3.8.3",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "ts-node": "10.9.2",
        "typescript": "6.0.3",
        "typescript-eslint": "8.59.0",
        "vitest": "4.1.4"
    },
    "dependencies": {
        "@types/history": "4.7.11",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@types/react-router": "5.1.20",
        "@types/react-router-dom": "5.3.3",
        "axios": "1.15.1",
        "core-js": "3.49.0",
        "eventsource": "4.1.0",
        "history": "4.10.1",
        "immer": "11.1.4",
        "react-redux": "9.2.0",
        "react-router": "5.2.1",
        "react-router-dom": "5.3.0",
        "redux": "5.0.1",
        "redux-first-history": "5.2.0",
        "redux-saga": "1.4.2",
        "regenerator-runtime": "0.14.1"
    },
    "peerDependencies": {
        "react": ">=19.0.0",
        "react-dom": ">=19.0.0"
    },
    "engines": {
        "node": ">=24"
    },
    "pnpm": {
        "overrides": {
            "glob": "13.0.6"
        }
    },
    "packageManager": "pnpm@10.33.0"
}
